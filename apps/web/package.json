{
  "name": "@collabhub/web",
  "version": "2.0.0-alpha.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc -p tsconfig.json && vite build",
